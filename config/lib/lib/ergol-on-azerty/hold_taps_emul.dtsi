#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

// clang-format off
#define EL_LAYER           7
#define EL_SLAYER          8
#define EL_1DK_LAYER       9
#define EL_S1DK_LAYER     10
#define EL_NUM_LOCK_LAYER 11
#define EL_SYMBOLS_LAYER  12
#define EL_SSYMBOLS_LAYER 13
#define EL_VIM_NAV_LAYER  14
#define EL_NUM_NAV_LAYER  15
#define EL_SNUM_NAV_LAYER 16
#define EL_NUM_ROW_LAYER  17
/**
 * Home Rew
 */

#if defined HT_HOME_ROW_MODS || defined HT_TWO_THUMB_KEYS
//  #define HRM_S &hrm LGUI S
  #define HRM_FR_A &hrm LCTL FR_A
  #define HRM_E &hrm LCTL E
  #define HRM_N &hrm LALT N
  #define HRM_R &hrm LALT R
  #define HRM_T &hrm RCTL T
  #define HRM_I &hrm RGUI I
  #define HRM_Z &hrm LSHIFT Z 
  //test for gaming layer --TODO
  #define HRM_GA &hrm LSHIFT A
  #define HRM_GZ &hrm LCTL   Z
#else
//  #define HRM_S &kp S
  #define HRM_E &kp E
  #define HRM_N &kp N
  #define HRM_R &kp R
  #define HRM_I &kp I
  #define HRM_T &kp T
#endif

/**
 * Thumb Keys
 */

#ifdef VIM_NAVIGATION
  #define EL_NAV_LAYER EL_VIM_NAV_LAYER
  #define EL_NUM_LAYER EL_NUM_ROW_LAYER
  #define EL_HRM_LAYER EL_NUM_ROW_LAYER
  #define EL_S34_LAYER EL_NUM_ROW_LAYER
//  #define REACH_TAP ESCAPE
#else
  #define EL_NAV_LAYER EL_NUM_NAV_LAYER
  #define EL_NUM_LAYER EL_NUM_NAV_LAYER
  #define EL_HRM_LAYER FUNCTION_LAYER
  #define EL_S34_LAYER EL_NUM_NAV_LAYER
 // #define REACH_TAP TAB
#endif

#if defined HT_TWO_THUMB_KEYS && !defined VIM_NAVIGATION
  #define EL_SYM_NUM_LAYER &sc EL_NUM_NAV_LAYER CAPSLOCK
#else
  #define EL_SYM_NUM_LAYER &EZ_SL(EL_NUM_LAYER)
#endif

#ifdef LHAND_SPACE
  #define EL_LTHUMB_TT  &hrm LCTL SPACE
  #define EL_RTHUMB_TT  &EL_magic_backspace
  #define EL_LTHUMB_HRM &lt EL_NAV_LAYER SPACE
  #define EL_RTHUMB_HRM &EL_magic_backspace
  #define EL_LTHUMB_S34 &lt EL_NAV_LAYER SPACE
  #define EL_RTHUMB_S34 &EL_magic_backspace_34_keys
 // #define EL_SHIFTED_LTHUMB_HRM &lt EL_SNUM_NAV_LAYER SPACE
  #define EL_SHIFTED_RTHUMB_HRM &sc EL_SNUM_NAV_LAYER BACKSPACE
#else
  #define EL_LTHUMB_TT  &mt LCTL BACKSPACE
  #define EL_RTHUMB_TT  &EL_magic_space
  #define EL_LTHUMB_HRM &sc EL_NAV_LAYER BACKSPACE
  #define EL_RTHUMB_HRM &lt EL_NAV_LAYER SPACE
  #define EL_LTHUMB_S34 &sc EL_NAV_LAYER BACKSPACE
  #define EL_RTHUMB_S34 &lt EL_S34_LAYER SPACE
 // #define EL_SHIFTED_LTHUMB_HRM &sc EL_SNUM_NAV_LAYER BACKSPACE
  #define EL_SHIFTED_RTHUMB_HRM &lt EL_SNUM_NAV_LAYER SPACE
#endif

#ifdef HT_NONE
  #define EL_LTHUMB_TUCK   &kp LALT
  #define EL_LTHUMB_HOME   &kp LCTL
  #define EL_LTHUMB_REACH  &kp LGUI
  #define EL_RTHUMB_REACH  &mo EL_NAV_LAYER
  #define EL_RTHUMB_HOME   &kp SPACE
  #define EL_RTHUMB_TUCK   &mo EL_SYMBOLS_LAYER
#elifdef HT_THUMB_TAPS
  #define EL_LTHUMB_TUCK   &EZ_SL(EL_SLAYER)
  #define EL_LTHUMB_HOME   EL_LTHUMB_TT
  #define EL_LTHUMB_REACH  &mt LGUI REACH_TAP
  #define EL_RTHUMB_REACH  &mt LALT ENTER
  #define EL_RTHUMB_HOME   EL_RTHUMB_TT
  #define EL_RTHUMB_TUCK   &EL_sym_shift_altgr
#elifdef HT_HOME_ROW_MODS
  #define EL_LTHUMB_TUCK   &EZ_SL(EL_SLAYER)
  #define EL_LTHUMB_HOME   EL_LTHUMB_HRM
  #define EL_LTHUMB_REACH  &sc EL_HRM_LAYER REACH_TAP
  #define EL_RTHUMB_REACH  &sc EL_HRM_LAYER ENTER
  #define EL_RTHUMB_HOME   EL_RTHUMB_HRM
  #define EL_RTHUMB_TUCK   &EL_sym_shift_altgr
  #define EL_SHIFTED_RTHUMB_HOME  EL_SHIFTED_RTHUMB_HRM
  #define EL_SHIFED_RTHUMB_TUCK &mo EL_SSYMBOLS_LAYER
  #define EL_SHIFTED_RTHUMB_REACH &kp LS(ENTER)
  // la ligne précédente doit être corrigée pour être dynamique
#elifdef HT_TWO_THUMB_KEYS
  #define EL_LTHUMB_TUCK   &mt LSHIFT REACH_TAP
  #define EL_LTHUMB_HOME   EL_LTHUMB_S34
  #define EL_LTHUMB_REACH  EL_LTHUMB_TUCK
  #define EL_RTHUMB_REACH  &sc EL_SYMBOLS_LAYER ENTER
  #define EL_RTHUMB_HOME   EL_RTHUMB_S34
  #define EL_RTHUMB_TUCK   EL_RTHUMB_REACH
#endif

//#define EZ_SL(layer)  bsl (layer) (layer)
//#define EZ_SK(mod)    bsk (mod) (mod)
//#define EL_EZ_LSK(mod)   lbsk (mod) (mod)

/ {
  behaviors {

    // mod-morphs to restore Shift+Space and Ctrl+Backspace for certain keymaps
    EL_magic_backspace: EL_magic_backspace {
      compatible = "zmk,behavior-mod-morph";
      #binding-cells = <0>;
      bindings = <&sc EL_NAV_LAYER BACKSPACE>, <&lt EL_NAV_LAYER SPACE>;
      mods      = <MOD_LSFT>;
      keep-mods = <MOD_LSFT>;
    };
    EL_Emagic_space: EL_magic_space {
      compatible = "zmk,behavior-mod-morph";
      #binding-cells = <0>;
      bindings = <&lt EL_NAV_LAYER SPACE>, <&sc EL_NAV_LAYER BACKSPACE>;
      mods      = <MOD_LCTL>;
      keep-mods = <MOD_LCTL>;
    };
    EL_magic_backspace_34_keys: EL_magic_backspace_34_keys {
      compatible = "zmk,behavior-mod-morph";
      #binding-cells = <0>;
      bindings = <&sc EL_HRM_LAYER BACKSPACE>, <&lt EL_HRM_LAYER SPACE>;
      mods      = <MOD_LSFT>;
      keep-mods = <MOD_LSFT>;
    };
  };

  // XXX this whole AltGr section should probably be inside the `behaviors` branch
  // AltGr support

  // Sym becomes Shift+AltGr when combined with exclusively Shift
  EL_sym_shift_altgr: EL_sym_shift_altgr {
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&EL_sym_shift_altgr_inner>, <&EZ_SL(EL_SYMBOLS_LAYER)>;
    mods      = <(MOD_LCTL|MOD_RCTL|MOD_LGUI|MOD_RGUI|MOD_LALT)>;
    keep-mods = <(MOD_LCTL|MOD_RCTL|MOD_LGUI|MOD_RGUI|MOD_LALT)>;
  };
  EL_sym_shift_altgr_inner: EL_sym_shift_altgr_inner {
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&EZ_SL(EL_SYMBOLS_LAYER)>, <&EZ_SK(RALT)>;
    mods      = <(MOD_LSFT|MOD_RSFT)>;
    keep-mods = <(MOD_LSFT|MOD_RSFT)>;
  };

  // go to base layer and press mod

  EL_lkp: EL_goto_layer_then_keypress {
    compatible = "zmk,behavior-macro-one-param";
    wait-ms = <0>;
    tap-ms = <0>;
    #binding-cells = <1>;
    bindings =
      <&macro_tap &to EL_LAYER>,
      <&macro_param_1to1>,
      <&macro_press &kp MACRO_PLACEHOLDER>,
      <&macro_pause_for_release>,
      <&macro_param_1to1>,
      <&macro_release &kp MACRO_PLACEHOLDER>;
  };
  EL_losm: EL_goto_layer_then_osm {
    compatible = "zmk,behavior-macro-one-param";
    wait-ms = <0>;
    tap-ms = <0>;
    #binding-cells = <1>;
    bindings =
      <&macro_tap &to EL_LAYER>,
      <&macro_param_1to1>,
      <&macro_tap &sk MACRO_PLACEHOLDER>;
  };
  EL_lbsk: EL_bsk_on_other_layer {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    tapping-term-ms = <TAPPING_TERM>;
    flavor = "tap-preferred";
    bindings = <&EL_lkp>, <&EL_losm>;
  };
};